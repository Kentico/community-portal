    <PackageVersion Include="Azure.Storage.Queues" Version="12.27.0" />
    <PackageVersion Include="CSharpFunctionalExtensions" Version="3.7.0" />
    <PackageVersion Include="CsvHelper" Version="33.1.0" />
    <PackageVersion Include="Enums.NET" Version="5.0.0" />
    <PackageVersion Include="Htmx" Version="1.12.0" />
    <PackageVersion Include="Htmx.TagHelpers" Version="1.12.0" />
    <PackageVersion Include="Kentico.Xperience.Admin" Version="31.5.4" />
    <PackageVersion Include="Kentico.Xperience.AzureStorage" Version="31.5.4" />
    <PackageVersion Include="Kentico.Xperience.Cloud" Version="31.5.4" />
