    <PackageVersion Include="Kentico.Xperience.Core" Version="31.5.4" />
    <PackageVersion Include="Kentico.Xperience.Core.Tests" Version="31.5.4" />
    <PackageVersion Include="Kentico.Xperience.ImageProcessing" Version="31.5.4" />
    <PackageVersion Include="Kentico.Xperience.Lucene" Version="15.0.3" />
    <PackageVersion Include="Kentico.Xperience.ManagementApi" Version="31.5.4-preview" />
    <PackageVersion Include="Kentico.Xperience.MiniProfiler" Version="3.0.0" />
    <PackageVersion Include="Kentico.Xperience.Mjml" Version="31.5.4" />
    <PackageVersion Include="Kentico.Xperience.SendGrid" Version="31.5.4" />
    <PackageVersion Include="Kentico.Xperience.TagManager" Version="6.1.0" />
    <PackageVersion Include="Kentico.Xperience.VirtualInbox.Admin" Version="1.3.0" />
    <PackageVersion Include="Kentico.Xperience.VirtualInbox.MCP" Version="1.3.0" />
    <PackageVersion Include="Kentico.Xperience.WebApp" Version="31.5.4" />
    <PackageVersion Include="Markdig" Version="1.3.0" />
    <!-- Temporary: explicit pin to non-vulnerable Magick.NET-Q8-AnyCPU version. Remove after upstream Xperience hotfix updates transitive dependency. -->
    <PackageVersion Include="Magick.NET-Q8-AnyCPU" Version="14.14.0" />
    <!-- Do not update - licensing restrictions for new versions limit commercial use -->
    <PackageVersion Include="Mediatr" Version="12.5.0" />
    <PackageVersion Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.9" />
    <PackageVersion Include="Microsoft.Data.SqlClient" Version="7.0.1" />
    <PackageVersion Include="Microsoft.Extensions.Configuration" Version="10.0.9" />
    <PackageVersion Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="10.0.9" />
    <PackageVersion Include="Microsoft.Extensions.Configuration.UserSecrets" Version="10.0.9" />
    <PackageVersion Include="Microsoft.Extensions.Http.Resilience" Version="10.6.0" />
    <PackageVersion Include="Microsoft.Extensions.ServiceDiscovery" Version="10.6.0" />
    <PackageVersion Include="Microsoft.Identity.Web" Version="4.10.0" />
    <PackageVersion Include="NSubstitute" Version="5.3.0" />
