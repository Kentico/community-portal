@model bool

@if (!Model)
{
    <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary"></div>
    return;
}

<xpc-alert test-id="confirmationEmailMessage">
    <p>
        You will receive a confirmation email.
    </p>
    <p>
        You can complete your registration by clicking the verification link in this email.
    </p>
</xpc-alert>