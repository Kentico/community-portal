            <AdditionalActionIdentifier>Kentico.Administration.AiraTextGeneration</AdditionalActionIdentifier>
            <AdditionalActionValues>
              <FieldDescription>
<![CDATA[
Newsletter title.

Separate from the email subject line, this field is the heading shown inside the email.
Write a concise, issue-specific heading that reflects the newsletter's theme or main takeaway.
Keep it scannable and useful for readers who already opened the email.
]]>
              </FieldDescription>
            </AdditionalActionValues>
          </AdditionalActionConfiguration>
        </additionalactionsdata>
      </field>
