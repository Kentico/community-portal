      <field column="AutoresponderEmailBodyContentHTML" columnprecision="0" columntype="richtexthtml" enabled="true" guid="bdb2afe2-b1f2-4b67-a055-9b2c17b7dccb" visible="true">
        <properties>
          <explanationtextashtml>False</explanationtextashtml>
          <fieldcaption>Content</fieldcaption>
          <fielddescriptionashtml>False</fielddescriptionashtml>
          <includeincontentgeneration>True</includeincontentgeneration>
        </properties>
        <settings>
          <ConfigurationName>
            <![CDATA[Kentico.Administration.EmailContentForAutoresponder]]>
          </ConfigurationName>
          <controlname>Kentico.Administration.RichTextEditor</controlname>
        </settings>
        <additionalactionsdata>
          <AdditionalActionConfiguration>
            <AdditionalActionIdentifier>Kentico.Administration.AiraTextRefinement</AdditionalActionIdentifier>
            <AdditionalActionValues />
          </AdditionalActionConfiguration>
          <AdditionalActionConfiguration>
            <AdditionalActionIdentifier>Kentico.Administration.AiraTextGeneration</AdditionalActionIdentifier>
            <AdditionalActionValues>
              <FieldDescription>
<![CDATA[
Email body content.

One email, one goal. Every automated email should have a single clear purpose tied to the trigger. Don't conflate nurture + upsell + feedback in one message.
Value first, ask second. Offer something useful — a tip, resource, or insight — before making any ask. Then one clear CTA: click, download, reply.
Write conversationally, not robotically. Write as if talking to a friend. Automation doesn't mean losing the personal touch — it means enhancing messages based on context.
]]>
              </FieldDescription>
            </AdditionalActionValues>
          </AdditionalActionConfiguration>
        </additionalactionsdata>
      </field>
