<?xml version="1.0" encoding="utf-8"?>
<emaillibrary.emailtemplate>
  <EmailTemplateCode>
<![CDATA[
<!DOCTYPE html>
{% emailDefaults = EmailDesignEmailDefaultsContent[0].Data; "" |(identity)GlobalAdministrator|(hash)2a213277bd7b34a8fec9c680b890fc8b2e076afb43e4d6bea8639017c3aa2e96%}
<html lang="en">
  <head>
    <title>{% AutoresponderEmailTitle %}</title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="color-scheme" content="light dark" />
    <!-- ios -->
    <meta name="supported-color-schemes" content="light dark" />
    <!-- ios -->
    <style type="text/css">
      {% emailDefaults.EmailDefaultsContentHTMLStyles |(identity)GlobalAdministrator|(hash)ac88fce2010491fe0e2b109c3b7336b67e867cb74936fe4ddfbdf08cac49b4e8%}
    </style>
  </head>
  <body style="margin: 0; padding: 0; height: 100%; width: 100%">
    <div style="display: none; font-size: 1px; color: #ffffff; line-height: 1px; max-height: 0px; max-width: 0px; opacity: 0; overflow: hidden;">{% previewtext %}</div>
    <!-- Insert &#847;&zwnj;&nbsp; hack after hidden preview text -->
    <div style="display: none; max-height: 0px; overflow: hidden;">
    &#847; &zwnj; &nbsp; &#8199; &shy; &#847; &zwnj; &nbsp; &#8199; &shy; &#847; &zwnj; &nbsp; &#8199; &shy; &#847; &zwnj; &nbsp; &#8199; &shy; &#847; &zwnj; &nbsp; &#8199; &shy; &#847; &zwnj; &nbsp; &#8199; &shy; &#847; &zwnj; &nbsp; &#8199; &shy; &#847; &zwnj; &nbsp; &#8199; &shy;
    </div>
    <div class="body" style="background-color: #fafafa">
      <div
        style="background-color: #fafafa; height: 66px"
        class="body-gap"
      ></div>
      <div
        role="article"
        aria-label="Kentico newsletter"
        class="body-bg"
        lang="en"
        style="
          background-color: #ffffff;
          color: #2b2b2b;
          font-family: Arial, 'Avenir Next', -apple-system, BlinkMacSystemFont,
            'Segoe UI', Roboto, Helvetica, sans-serif, 'Apple Color Emoji',
            'Segoe UI Emoji', 'Segoe UI Symbol';
          font-size: 18px;
          font-weight: 400;
          line-height: 28px;
          margin: 0 auto;
          max-width: 540px;
          padding: 30px;
        "
      >
        <header>
          <div
            style="
              display: inline-block;
              margin: 0;
              width: 100%;
              min-width: 200px;
              max-width: 270px;
              vertical-align: bottom;
            "
            class="logo"
          >
            <a
              href="{% emailDefaults.EmailDefaultsContentLogoLinkURL |(identity)GlobalAdministrator|(hash)08cc37bb780b9dce8d62cef0ec457b862696b5672c7a036d0924a6400e740312%}"
              title="{% HTMLEncode(emailDefaults.EmailDefaultsContentLogoLinkURL) |(identity)GlobalAdministrator|(hash)b0eb2dfd17b0d7ff1b7309327cd6f43d75b401d113edee8e9cc349984c68cfc4%}"
              style="width: 174px; display: inline-block"
              target="_blank"
            >
              {% headerLogoLight = emailDefaults.EmailDefaultsContentLogoLightImageContent[0].Data; "" |(identity)GlobalAdministrator|(hash)e0fb53190ebb8b66f3d588f992be5134d7a683395232163edee0fe50a05f203d%}
              {% headerLogoDark = emailDefaults.EmailDefaultsContentLogoDarkImageContent[0].Data; "" |(identity)GlobalAdministrator|(hash)679f1394a5a05702809e0e8a2caae568df548df444c6c39796c421f9c15bcf5e%}
              <img
                class="light-img"
                src="{% headerLogoLight.ImageContentAsset.Url |(identity)GlobalAdministrator|(hash)e281f05fb433aaaab04c7bb23f6bb9327fc986862fa7ac5e747619d0da46bcb2%}"
                alt="{% HTMLEncode(headerLogoLight.MediaItemTitle) |(identity)GlobalAdministrator|(hash)26fc5b059f41ce4837f2c3b0aa795ebea627bbf4c6fadc3ba8111196cd946cf0%}"
                style="width: 150px;"
              />
              <div
                class="dark-img"
                style="
                  display: none;
                  overflow: hidden;
                  float: left;
                  width: 0px;
                  max-height: 0px;
                  max-width: 0px;
                  line-height: 0px;
                  visibility: hidden;
                "
              >
                <img
                  src="{% headerLogoDark.ImageContentAsset.Url |(identity)GlobalAdministrator|(hash)620037c4013d863f892c0f2aa1b3c291e4a06fb30a13c0d447947a50cf03b319%}"
                  alt="{% HTMLEncode(headerLogoDark.MediaItemTitle) |(identity)GlobalAdministrator|(hash)47b3ac0723b06305660af2337cec7976d74db70639537fe16f8e5e48bfcf77e9%}"
                  style="width: 150px;"
                />
              </div>
            </a>
          </div>
        </header>
        {% AutoresponderEmailBodyContentHTML %}
      </div>
      <div
        class="footer"
        style="
          background-color: #f4f4f4;
          margin: 0 auto;
          max-width: 600px;
          font-family: Arial, 'Avenir Next', -apple-system, BlinkMacSystemFont,
            'Segoe UI', Roboto, Helvetica, sans-serif, 'Apple Color Emoji',
            'Segoe UI Emoji', 'Segoe UI Symbol';
        "
      >
        <footer style="margin: 0; padding: 0">
          <h2
            style="
              color: #000000;
              font-size: 22px;
              line-height: 24px;
              font-weight: bold;
              padding: 56px 40px 0 40px;
              margin-top: 0;
              margin-bottom: 0;
              text-align: left;
            "
            class="footer__heading"
          >
            Meet Kentico on social networks
            <span class="orange-char" style="color: #f05a22">.</span>
          </h2>
          <div
            style="
              padding-left: 30px;
              padding-top: 20px;
              padding-bottom: 30px;
              height: 48px;
            "
          >
            <table
              role="presentation"
              align="left"
              border="0"
              cellpadding="0"
              cellspacing="0"
              width="160"
            >
              <tbody>
                <tr>
                  {% foreach (link in emailDefaults.EmailDefaultsContentSocialLinks) { %}
                  <td
                    style="
                      text-align: left;
                      padding: 0px;
                      width: 40px;
                      height: 40px;
                    "
                  >
                    <a
                      href="{% link.Data.SocialLinkContentURL.ReplaceUtmParameters(AutoresponderEmailUTMParameters) %}"
                      title="{% HTMLEncode(link.Data.SocialLinkContentURL.ReplaceUtmParameters(AutoresponderEmailUTMParameters)) %}"
                      target="_blank"
                      style="
                        display: inline-block;
                        border: 0px none;
                        margin: 0px;
                        padding: 8px;
                      "
                      title="Join us on {% HTMLEncode(link.Data.SocialLinkContentTitle) %}"
                    >
                      <img
                        alt="{% HTMLEncode(link.Data.SocialLinkContentTitle) %}"
                        src="{% link.Data.SocialLinkContentLogoLightImage.Url %}"
                        width="32"
                        height="32"
                        style="
                          width: 32px;
                          height: 32px;
                          border: 0px none;
                          margin: 0px;
                          padding: 0px;
                          display: block;
                        "
                        class="light-img"
                      />
                      <div
                        class="dark-img"
                        style="
                          display: none;
                          overflow: hidden;
                          float: left;
                          width: 0px;
                          max-height: 0px;
                          max-width: 0px;
                          line-height: 0px;
                          visibility: hidden;
                        "
                      >
                        <img
                          alt="{% HTMLEncode(link.Data.SocialLinkContentTitle) %}"
                          src="{% link.Data.SocialLinkContentLogoDarkImage.Url %}"
                          width="32"
                          height="32"
                        />
                      </div>
                    </a>
                  </td>
                 {% } |(identity)GlobalAdministrator|(hash)ac17a29824482a847fd074e8dba3d05ce1349876b55951246dc2c3d7febb4318%}
                </tr>
              </tbody>
            </table>
          </div>
          <div style="padding: 0 40px">
            <div
              style="background-color: #b2b2b2; height: 1px; padding: 0"
            ></div>
          </div>
          <p
            style="
              color: #4f4c4d;
              font-size: 16px;
              font-weight: 400;
              line-height: 24px;
              padding: 40px 40px;
              margin-top: 0;
              text-align: left;
              display: inline-block;
            "
          >
            <a
              href="{% emailDefaults.EmailDefaultsContentDefaultURL.ReplaceUtmParameters(AutoresponderEmailUTMParameters) |(identity)GlobalAdministrator|(hash)3a0120260dcde4770d461fb90c07995b1afe66741ca1145b0b7d9741e1a0fa7a%}"
              title="{% HTMLEncode(emailDefaults.EmailDefaultsContentDefaultURL.ReplaceUtmParameters(AutoresponderEmailUTMParameters)) |(identity)GlobalAdministrator|(hash)9a689c304c6bcff2f1f6af3d490c01aace4dc4d1665a87e2bfd7974f0f38016a%}"
              style="color: #4f4c4d; text-decoration: none"
              >Kentico software s.r.o.</a
            >, Nove sady 25, 602 00 Brno, Czech Republic.
          </p>
          <div
            style="
              padding: 0 40px 40px 40px;
              text-align: left;
              display: block;
              background-color: #f4f4f4;
            "
            class="footer__logo"
          >
            <a
              href="{% emailDefaults.EmailDefaultsContentLogoLinkURL.ReplaceUtmParameters(AutoresponderEmailUTMParameters) |(identity)GlobalAdministrator|(hash)c2b959207b87ebab27dbcfa5d28595dcb9901dad51726bb8eca139a4754a9a11%}"
              title="{% HTMLEncode(emailDefaults.EmailDefaultsContentLogoLinkURL.ReplaceUtmParameters(AutoresponderEmailUTMParameters)) |(identity)GlobalAdministrator|(hash)2a10abef32fc69a7b8af8cbcbea6f8583dd5bf657c5cea99c92fe4a86a7c4d57%}"
              style="width: 150px; display: inline-block"
              target="_blank"
            >
              {% footerLogoLight = emailDefaults.EmailDefaultsContentLogoLightImageContent[0].Data; "" |(identity)GlobalAdministrator|(hash)2835f695a1026a5912f1a451b3547c607207559f3d19c11a4e64a7b97d41fc9b%}
              {% footerLogoDark = emailDefaults.EmailDefaultsContentLogoDarkImageContent[0].Data; "" |(identity)GlobalAdministrator|(hash)fe525f56d2af8f59cc0777a07afbfabfada4fd1cf4f6025341ff993e0bf6f083%}
              <img
                class="light-img"
                src="{% footerLogoLight.ImageContentAsset.Url |(identity)GlobalAdministrator|(hash)1fb8fe32c0038ba929fb1a832b608b885f5a11104764863407074a079e96383b%}"
                alt="{% HTMLEncode(footerLogoLight.MediaItemTitle) |(identity)GlobalAdministrator|(hash)c986893edcc7e36e011c30ec0db59152949bacb114c5b4e54130ce1198b43944%}"
                style="width: 150px;"
              />
              <div
                class="dark-img"
                style="
                  display: none;
                  overflow: hidden;
                  float: left;
                  width: 0px;
                  max-height: 0px;
                  max-width: 0px;
                  line-height: 0px;
                  visibility: hidden;
                "
              >
                <img
                  src="{% footerLogoDark.ImageContentAsset.Url |(identity)GlobalAdministrator|(hash)369848b2e7391ccecbe35b71fb06cbd9d707e3a2f3d965a3f98042bced0b86df%}"
                  alt="{% HTMLEncode(footerLogoDark.MediaItemTitle) |(identity)GlobalAdministrator|(hash)2c8ded428523ad1140c998b47ab9b826ea3cffefa11bd7db53ede66e66c3f3e6%}"
                  style="width: 150px;"
                />
              </div>
            </a>
          </div>
        </footer>
      </div>
    </div>
    <div
      style="background-color: #fafafa; height: 30px; border: none"
      class="body-gap"
    ></div>
  </body>
</html>

]]>
  </EmailTemplateCode>
  <EmailTemplateDisplayName>Community Autoresponder</EmailTemplateDisplayName>
