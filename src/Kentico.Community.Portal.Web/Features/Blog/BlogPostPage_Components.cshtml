@using Kentico.Community.Portal.Web.Components.TagHelpers
@using Kentico.Community.Portal.Web.Features.Blog

@model TemplateViewModel<BlogPostPageTemplateProperties>

@{
    ClientAssets.RequirePrism();
    var post = Model.GetTemplateModel<BlogPostPageViewModel>();
}

<main>
    <div class="t-article">
        <div class="content-wrapper">
            <section class="section" style="--section-padding-block: 0;">
                <section class="template-banner blog position-relative min-vh-50">
                    <div class="position-absolute top-0 start-0 w-100 h-100 overflow-hidden">
                        <partial name="~/Features/Blog/_BlogHero.cshtml" />
                    </div>
                    <div class="container-fluid position-relative">
                        <div class="row">
                            <div class="col col-md-6 offset-md-3">
                                <div class="text-center py-5 my-4">
                                    <h1>@post.Title</h1>
                                    <time xpc-datetime="post.PublishedDate" xpc-datetime-format="@DateTimeFormat.Date"
                                          class="text-muted">
                                    </time>
                                    <div class="d-flex align-items-center justify-content-center mt-3">
                                        <div class="me-3">
                                            <img xpc-image="post.Author.Photo" class="rounded-circle"
                                                 style="width: 50px; height: 50px;" />
                                        </div>
                                        <div>
                                            @if (post.Author.LinkProfilePath.TryGetValue(out string? p1))
                                            {
                                                <a href="@p1" class="text-decoration-none">@post.Author.Name</a>
                                            }
                                            else
                                            {
                                                @post.Author.Name
                                            }
                                            @if (post.Author.Title.TryGetValue(out string? title))
                                            {
                                                <div class="text-muted small">@title</div>
                                            }
                                        </div>
                                    </div>
                                    <div class="mt-4">
                                        @if (post.Upvote.TryGetValue(out var upvoteTop))
                                        {
                                            <div id="blog-upvote-top">
                                                <partial name="~/Features/Blog/_BlogPostUpvote.cshtml" model="upvoteTop" />
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </section>

            <section class="section section--default ps-0 pe-0">
                <div role="main" class="t-article_body">
                    <editable-area area-identifier="main" area-options-default-section-identifier="@SI.SingleColumn"
                        area-options-allowed-sections="
                        [
                            SI.Grid,
                            SI.SingleColumn
                        ]" area-options-allowed-widgets="
                        [
                            WI.BlogPostList,
                            WI.CTAButton,
                            WI.Carousel,
                            WI.File,
                            WI.Heading,
                            WI.Image,
                            WI.LinkList,
                            WI.Markdown,
                            WI.Video,
                            WI.ProfileCard,
                            WI.Embed,
                            WI.FallbackForm,
                            WI.Poll,
                            WI.Testimonial,
                            WI.Integration
                        ]"
                    allow-widget-output-cache="View.CacheEnabled"
                     widget-output-cache-expires-after="TimeSpan.FromMinutes(5)" />
                </div>

                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-md-10 col-lg-9 col-xl-8">
                            <div class="mt-6">
                                @if (post.DiscussionLinkPath.TryGetValue(out string? discussionPath))
                                {
                                    string message = post.DiscussionCommentsCount switch
                                    {
                                        0 => "Start a discussion about this post",
                                        1 => "Join the conversation (1 comment)",
                                        _ => $"Join the conversation ({post.DiscussionCommentsCount} comments)"
                                    };

                                    <div class="d-flex align-items-center justify-content-center gap-3 flex-wrap">
                                        @if (post.Upvote.TryGetValue(out var upvoteBottom))
                                        {
                                            <div id="blog-upvote-bottom">
                                                <partial name="~/Features/Blog/_BlogPostUpvote.cshtml" model="upvoteBottom" />
                                            </div>
                                        }
                                        <a class="btn btn-secondary" href="@discussionPath">
                                            @message
                                        </a>
                                    </div>
                                }
                                else if (post.Upvote.TryGetValue(out var upvoteOnly))
                                {
                                    <div class="d-flex align-items-center justify-content-center">
                                        <div id="blog-upvote-bottom">
                                            <partial name="~/Features/Blog/_BlogPostUpvote.cshtml" model="upvoteOnly" />
                                        </div>
                                    </div>
                                }
                                <div class="mt-4 text-center">
                                    <p>Share on:</p>
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="https://twitter.com/intent/tweet?url=@post.AbsoluteURL" target="_blank"
                                               rel="noopener noreferrer" title="Twitter"
                                               class="btn btn-secondary btn-social border-0 bg-twitter">
                                            <svg class="icon">
                                                <use xlink:href="/img/icons.svg#brand-twitter" asp-append-version />
                                            </svg>
                                        </a>
                                        <a href="https://www.facebook.com/sharer/sharer.php?u=@post.AbsoluteURL"
                                               target="_blank" rel="noopener noreferrer" title="Facebook"
                                               class="btn btn-secondary btn-social border-0 bg-facebook">
                                            <svg class="icon">
                                                <use xlink:href="/img/icons.svg#brand-facebook" asp-append-version />
                                            </svg>
                                        </a>
                                        <a href="https://www.linkedin.com/shareArticle?url=@post.AbsoluteURL"
                                               target="_blank" rel="noopener noreferrer" title="LinkedIn"
                                               class="btn btn-secondary btn-social border-0 bg-linkedin">
                                            <svg class="icon">
                                                <use xlink:href="/img/icons.svg#brand-linkedin" asp-append-version />
                                            </svg>
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="card border mt-5">
                                <div class="card-body d-flex align-items-center">
                                    <div class="me-3">
                                        @if (post.Author.Photo.TryGetValue(out var photo))
                                        {
                                            <img xpc-image="photo" class="rounded-circle"
                                                 style="width: 50px; height: 50px;" />
                                        }
                                        else
                                        {
                                            <img src="/img/profile-photo-default.png" alt="@post.Author.Name"
                                                 class="rounded-circle" style="width: 50px; height: 50px;" />
                                        }
                                    </div>
                                    <div>
                                        <h4 class="h5 mb-0">
                                            @if (post.Author.LinkProfilePath.TryGetValue(out string? p2))
                                            {
                                                <a class="text-primary" href="@p2">@post.Author.Name</a>
                                            }
                                            else
                                            {
                                                @post.Author.Name
                                            }
                                        </h4>
                                        <div class="text-muted small">@post.Author.BiographyHTML</div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>

    @if (Model.Properties.ShowTableOfContents)
    {
    <div x-cloak x-data="tableOfContents()" x-show="hasHeadings" class="blog-toc" role="navigation" aria-label="Table of contents">
        <nav id="blog-toc-panel" class="blog-toc__panel" x-show="isOpen" x-transition aria-label="In this article">
            <div class="blog-toc__panel-header">
                <span>In this article</span>
                <button class="blog-toc__close" @@click="close()" aria-label="Close table of contents">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                    </svg>
                </button>
            </div>
            <ol class="blog-toc__list">
                <template x-for="item in headings" :key="item.id">
                    <li class="blog-toc__item" :class="`blog-toc__item--${item.level}`">
                        <a href="#" class="blog-toc__link" :class="{ 'blog-toc__link--active': activeId === item.id }" @@click.prevent="navigateTo(item.id)" x-text="item.text"></a>
                    </li>
                </template>
            </ol>
        </nav>
        <button class="blog-toc__toggle" @@click="toggle()" :aria-expanded="isOpen.toString()" aria-controls="blog-toc-panel">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
            </svg>
            <span class="blog-toc__toggle-label">Contents</span>
        </button>
    </div>
    }
</main>