@using Kentico.Community.Portal.Web.Features.QAndA

@model QAndAQuestionReactionViewModel

@{
    string reactionFormId = $"reactionForm_{Model.QuestionID:N}";
    var toolTipAttrs = Html.Raw(BuildTooltipAttrs());
}

@if (Model.Permissions.CanReact)
{
    <form id="@reactionFormId" method="post" hx-post hx-controller="QAndAQuestion" hx-action="UpdateQuestionReaction"
        hx-route-questionID="@Model.QuestionID" hx-swap="outerHTML" hx-target="#@reactionFormId">
        <fieldset xpc-readonly-disabled>
            <button type="submit"
                class="badge outline rounded-pill d-inline-flex align-items-center justify-content-center gap-2 px-2 py-1 text-nowrap qa-upvote-btn @(Model.CurrentMemberHasReacted ? "selected" : "")"
                theme="secondary" @(toolTipAttrs)>
                <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                    <use xlink:href="/img/icons.svg#thumbs-up" asp-append-version />
                </svg>
                @Model.ReactionCount
            </button>
        </fieldset>
    </form>
}
else
{
    <button type="button" disabled
        class="badge outline rounded-pill d-inline-flex align-items-center justify-content-center gap-2 px-2 py-1 text-nowrap qa-upvote-btn"
        theme="secondary" @(toolTipAttrs)>
        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
            <use xlink:href="/img/icons.svg#thumbs-up" asp-append-version />
        </svg>
        @Model.ReactionCount
    </button>
}

@{
    string BuildTooltipAttrs()
    {
        // Always include member list if reactions exist
        var memberList = Model.ReactionCount > 0
        ? $"Upvoted by: {Html.Encode(string.Join(", ", Model.MembersWhoReacted))}"
        : "";

        // Case 1: Can react - show "be first" prompt or member list
        if (Model.Permissions.CanReact)
        {
            var title = string.IsNullOrEmpty(memberList)
            ? "Be the first to upvote this discussion"
            : memberList;
            return $"data-bs-toggle='tooltip' data-bs-html='true' data-bs-delay='1000' data-bs-placement='top' data-bs-title='{title}'";
        }

        // Case 2 & 3: Cannot react - combine member list with disable reason
        var reason = User.Identity?.IsAuthenticated ?? false
        ? "You cannot upvote your own discussion"
        : "Sign in to upvote discussions";

        var message = !string.IsNullOrEmpty(memberList)
        ? $"{reason}<br>{memberList}"
        : reason;

        return $"data-bs-toggle='tooltip' data-bs-html='true' data-bs-delay='1000' data-bs-placement='top' data-bs-title='{message}'";
    }
}