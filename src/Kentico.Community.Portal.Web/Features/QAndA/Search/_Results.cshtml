@using Kentico.Community.Portal.Web.Features.QAndA.Search

@model QAndASearchViewModel

@foreach (var discussion in Model.Discussions)
{
    <article
        class="border rounded-3 p-3 d-grid overflow-y-auto gap-1 qa-question-card @(discussion.HasAcceptedResponse ? "qa-question-card--success" : "")"
        style="grid-template-columns: 1fr; grid-template-areas: 'card-content' 'card-footer';"
        aria-describedby="responses-@discussion.ID">
        <div class="d-md-flex justify-content-between gap-1" style="grid-area: card-content;">
            <div>
                @if (discussion.HasAcceptedResponse)
                {
                    <div class="d-flex align-items-center text-success mb-2" role="status"
                         aria-label="This question has an accepted answer">
                        <svg class="me-2" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                            <use xlink:href="/img/icons.svg#check" asp-append-version />
                        </svg>
                        <small class="fw-bold">Has Accepted Response</small>
                    </div>
                }

                <header>
                    <h3 class="h3">
                        <a href="@discussion.LinkPath" rel="nofollow"
                               class="text-dark text-decoration-none qa-question-link"
                               aria-describedby="date-@discussion.ID author-@discussion.ID">
                            @discussion.Title
                        </a>
                    </h3>

                    <div class="d-none d-md-block">
                        <div id="author-@discussion.ID" class="mb-2">
                            <vc:author author="discussion.Author" />
                        </div>
                        Discussion created<br>
                        <time id="date-@discussion.ID" xpc-datetime="discussion.DateCreated" class="text-muted small">
                        </time>
                    </div>
                </header>
            </div>
            @{
                string responseText = discussion.ResponseCount switch
                {
                    0 or > 1 => "responses",
                    1 => "response",
                    _ => ""
                };
            }
            <div id="responses-@discussion.ID" class="d-none d-md-flex flex-column justify-content-between text-end ms-auto"
                 aria-label="@discussion.ResponseCount @responseText">
                <div class="fs-5">
                    <span class="text-secondary fw-bold lh-sm">@discussion.ResponseCount</span>
                    @responseText
                </div>

                @if (discussion.ResponseCount > 0)
                {
                    <div class="mt-1">
                        Latest response<br>
                        <time xpc-datetime="discussion.LatestResponseDate" class="text-muted small">
                        </time>
                    </div>
                }
            </div>
        </div>
        <footer style="grid-area: card-footer;"
            class="d-flex flex-row justify-content-between align-items-end gap-2">
            <div class="flex-grow-1 w-100">
                <div class="d-md-none">
                    <vc:author author="discussion.Author" />
                    Discussion created<br>
                    <time xpc-datetime="discussion.DateCreated" class="text-muted small">
                    </time>
                </div>
                @if (discussion.Tags.Count > 0 || discussion.HasAnyUpvotes)
                {
                    <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                        @if (discussion.Tags.Count > 0)
                        {
                            <div class="flex-grow-1">
                                <vc:tag-list tags="discussion.Tags" variant="Secondary" aria-label="Discussion topics" />
                            </div>
                        }
                        @if (discussion.HasAnyUpvotes)
                        {
                            <div class="d-none d-md-flex align-items-center justify-content-end ms-auto">
                                <span class="badge outline rounded-pill d-inline-flex align-items-center justify-content-center gap-1 text-nowrap" theme="secondary" role="img"
                                      aria-label="@discussion.DiscussionUpvoteSummary" tabindex="0" data-bs-toggle="tooltip"
                                      data-bs-placement="top" data-bs-title="@discussion.DiscussionUpvoteSummary">
                                    <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                                        <use xlink:href="/img/icons.svg#thumbs-up" asp-append-version />
                                    </svg>
                                    @if (discussion.HasQuestionUpvotes)
                                    {
                                        <span class="d-inline-flex align-items-center gap-1" aria-hidden="true">
                                            <span class="qa-question-card__vote-kpi-count">@discussion.QuestionUpvotes</span>
                                        </span>
                                    }
                                    @if (discussion.HasQuestionUpvotes && discussion.HasAnswerUpvotes)
                                    {
                                        <span class="qa-question-card__vote-divider" aria-hidden="true"></span>
                                    }
                                    @if (discussion.HasAnswerUpvotes)
                                    {
                                        <span class="d-inline-flex align-items-center gap-1" aria-hidden="true">
                                            <span class="qa-question-card__vote-kpi-count">@discussion.AnswerUpvotes</span>
                                        </span>
                                    }
                                </span>
                            </div>
                        }
                    </div>
                }
            </div>
            <div id="responses-m-@discussion.ID" class="d-flex d-md-none flex-column align-items-end text-end ms-auto flex-shrink-0 h-100 @(discussion.HasAnyUpvotes ? "justify-content-between" : "justify-content-center")"
                 aria-label="@discussion.ResponseCount @responseText">
                <div>
                    <div class="fs-5 text-nowrap">
                        <span class="text-secondary fw-bold lh-sm">@discussion.ResponseCount</span>
                        @responseText
                    </div>

                    @if (discussion.ResponseCount > 0)
                    {
                        <div class="mt-1">
                            Latest response<br>
                            <time xpc-datetime="discussion.LatestResponseDate" class="text-muted small">
                            </time>
                        </div>
                    }
                </div>

                @if (discussion.HasAnyUpvotes)
                {
                    <div class="d-flex align-items-center justify-content-end mt-2">
                        <span class="badge outline rounded-pill d-inline-flex align-items-center justify-content-center gap-2 px-2 py-1 text-nowrap" theme="secondary" role="img"
                              aria-label="@discussion.DiscussionUpvoteSummary" tabindex="0" data-bs-toggle="tooltip"
                              data-bs-placement="top" data-bs-title="@discussion.DiscussionUpvoteSummary">
                            <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
                                <use xlink:href="/img/icons.svg#thumbs-up" asp-append-version />
                            </svg>
                            @if (discussion.HasQuestionUpvotes)
                            {
                                <span class="d-inline-flex align-items-center gap-1" aria-hidden="true">
                                    <span class="qa-question-card__vote-kpi-count">@discussion.QuestionUpvotes</span>
                                </span>
                            }
                            @if (discussion.HasQuestionUpvotes && discussion.HasAnswerUpvotes)
                            {
                                <span class="qa-question-card__vote-divider" aria-hidden="true"></span>
                            }
                            @if (discussion.HasAnswerUpvotes)
                            {
                                <span class="d-inline-flex align-items-center gap-1" aria-hidden="true">
                                    <span class="qa-question-card__vote-kpi-count">@discussion.AnswerUpvotes</span>
                                </span>
                            }
                        </span>
                    </div>
                }
            </div>
        </footer>
    </article>
}

@if (Model.SearchResultState == SearchResultStates.IndexUnavailable)
{
    <div class="d-flex justify-content-center mt-5">
        <p>The search index is being updated. Please try again in a few minutes.</p>
    </div>
}
else if (Model.SearchResultState == SearchResultStates.NoResults)
{
    <div class="d-flex justify-content-center mt-5">
        <p>No results could be found.</p>
    </div>
}

<vc:pagination model="Model" />

<script type="module">
    asyncReady(async () => {
    const path = @JSEncoder.EncodeToJson(ClientAssets.ViteAssetPath("js/search.js"));
    const search = await import(path);

    search.initSearch({ formElemID: 'search' });
    });
</script>