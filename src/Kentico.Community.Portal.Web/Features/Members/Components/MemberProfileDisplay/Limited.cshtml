@using Kentico.Community.Portal.Web.Features.Members.Components.MemberProfileDisplay
@model ProfileRenderModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-warning">
                <div class="card-header bg-warning">
                    <h3 class="mb-0"><i class="bi bi-shield-fill-exclamation me-2"></i>Account Disabled</h3>
                </div>
                <div class="card-body text-center py-5">
                    <p class="lead mb-4">
                        This account was identified as spam and has been disabled.
                    </p>
                    <p class="text-muted">
                        Member details are unavailable.
                    </p>
                    <a href="/" class="btn btn-outline-secondary mt-3">Return Home</a>
                </div>
            </div>
        </div>
    </div>
</div>
