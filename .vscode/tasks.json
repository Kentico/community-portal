{
  "version": "2.0.0",
  "tasks": [
    {
      "label": ".NET: build (Solution)",
      "type": "shell",
      "command": "./Build-Solution.ps1",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": ".NET: rebuild (Solution)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "--no-incremental",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": ".NET: deep clean (Solution)",
      "type": "shell",
      "command": "./DeepClean-BuildArtifacts.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": ".NET: publish (Web)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/src/Kentico.Community.Portal.Web/Kentico.Community.Portal.Web.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": ".NET: watch (Web)",
      "command": "dotnet",
      "type": "process",
      "args": ["watch"],
      "options": {
        "cwd": "${workspaceFolder}/src/Kentico.Community.Portal.Web",
        "env": {
          "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true"
        }
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": ".NET: run (Web)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/Kentico.Community.Portal.Web/Kentico.Community.Portal.Web.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": ".NET: test (Solution)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        // https://learn.microsoft.com/en-us/dotnet/core/testing/unit-testing-nunit-runner-intro
        "--settings",
        "./test/basic.runsettings",
        "--no-build"
      ],
      "problemMatcher": "$msCompile",
      "isTestCommand": true
    },
    {
      "label": ".NET: format (Solution)",
      "command": "dotnet",
      "type": "process",
      "args": ["format"],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "npm: install (Web)",
      "type": "npm",
      "script": "install",
      "group": "none",
      "problemMatcher": [],
      "path": "src/Kentico.Community.Portal.Web",
      "detail": "Install Web npm dependencies"
    },
    {
      "label": "npm: audit fix (Web)",
      "type": "shell",
      "options": {
        "cwd": "src/Kentico.Community.Portal.Web"
      },
      "command": "npm audit fix",
      "problemMatcher": []
    },
    {
      "label": "npm: install (Admin)",
      "type": "npm",
      "script": "install",
      "path": "src/Kentico.Community.Portal.Admin/Client",
      "group": "none",
      "problemMatcher": [],
      "detail": "Install Admin npm dependencies"
    },
    {
      "label": "npm: audit fix (Admin)",
      "type": "shell",
      "options": {
        "cwd": "src/Kentico.Community.Portal.Admin/Client"
      },
      "command": "npm audit fix",
      "problemMatcher": []
    },
    {
      "label": "npm: watch (Web)",
      "type": "npm",
      "script": "start",
      "problemMatcher": [],
      "path": "src/Kentico.Community.Portal.Web",
      "dependsOn": ["npm: install (Web)"],
      "detail": "Vite development server"
    },
    {
      "label": "npm: watch (Admin)",
      "type": "npm",
      "script": "start",
      "group": "build",
      "problemMatcher": [],
      "path": "src/Kentico.Community.Portal.Admin/Client",
      "dependsOn": ["npm: install (Admin)"],
      "detail": "Webpack development server"
    },
    {
      "label": "npm: build (Web)",
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": [],
      "path": "src/Kentico.Community.Portal.Web",
      "dependsOn": ["npm: install (Web)"],
      "detail": "Build Web client assets (CSS, JS) with Vite"
    },
    {
      "label": "npm: install (Playwright E2E)",
      "type": "npm",
      "script": "install",
      "group": "none",
      "problemMatcher": [],
      "path": "test/kentico-community-portal-web-e2e-tests",
      "detail": "Install Playwright E2E npm dependencies"
    },
    {
      "label": "npm: install browsers (Playwright E2E)",
      "type": "npm",
      "script": "install:browsers",
      "group": "none",
      "problemMatcher": [],
      "path": "test/kentico-community-portal-web-e2e-tests",
      "dependsOn": ["npm: install (Playwright E2E)"],
      "detail": "Install Chromium for Playwright E2E"
    },
    {
      "label": "npm: audit fix (Playwright E2E)",
      "type": "shell",
      "options": {
        "cwd": "test/kentico-community-portal-web-e2e-tests"
      },
      "command": "npm audit fix",
      "problemMatcher": []
    },
    {
      "label": "npm: test (Playwright E2E)",
      "type": "npm",
      "script": "test",
      "problemMatcher": [],
      "options": {
        "env": {
          "NODE_OPTIONS": "--no-warnings"
        }
      },
      "path": "test/kentico-community-portal-web-e2e-tests",
      "dependsOn": ["npm: install browsers (Playwright E2E)"],
      "detail": "Run Playwright E2E tests"
    },
    {
      "label": "npm: test headed (Playwright E2E)",
      "type": "npm",
      "script": "test:headed",
      "problemMatcher": [],
      "options": {
        "env": {
          "NODE_OPTIONS": "--no-warnings"
        }
      },
      "path": "test/kentico-community-portal-web-e2e-tests",
      "dependsOn": ["npm: install browsers (Playwright E2E)"],
      "detail": "Run Playwright E2E tests in headed mode"
    },
    {
      "label": "npm: test UI (Playwright E2E)",
      "type": "npm",
      "script": "test:ui",
      "problemMatcher": [],
      "options": {
        "env": {
          "NODE_OPTIONS": "--no-warnings"
        }
      },
      "path": "test/kentico-community-portal-web-e2e-tests",
      "dependsOn": ["npm: install browsers (Playwright E2E)"],
      "detail": "Run Playwright E2E tests in UI mode"
    },
    {
      "label": "npm: test smoke (Playwright E2E)",
      "type": "npm",
      "script": "test:smoke",
      "problemMatcher": [],
      "options": {
        "env": {
          "NODE_OPTIONS": "--no-warnings"
        }
      },
      "path": "test/kentico-community-portal-web-e2e-tests",
      "dependsOn": ["npm: install browsers (Playwright E2E)"],
      "detail": "Run Playwright E2E smoke tests"
    },
    {
      "label": "npm: report (Playwright E2E)",
      "type": "npm",
      "script": "report",
      "problemMatcher": [],
      "path": "test/kentico-community-portal-web-e2e-tests",
      "detail": "Open Playwright HTML report"
    },
    {
      "label": "Xperience: CI Store",
      "detail": "Updates the CI repository with all valid objects from the local database",
      "type": "shell",
      "command": "./Store-CI.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: CI Restore",
      "detail": "Updates the local database with all the objects in the CI repository",
      "type": "shell",
      "command": "./Restore-CI.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: Application Update",
      "detail": "Updates local database data and schema to the version of the project's referenced Xperience NuGet package",
      "type": "shell",
      "command": "./Update-Xperience.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: Database Backup",
      "detail": "Creates a .bak of the Kentico Community database",
      "type": "shell",
      "command": "./Backup-Database.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: Update Generated Code Files",
      "detail": "Updates generated code files in the repository (uses script settings)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/Refresh-GeneratedCode.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: Generate Deployment Package",
      "detail": "Generates a deployment package of the project for the Xperience SaaS environment",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/Export-DeploymentPackage.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "MailHog: Start Server",
      "detail": "Starts MailHog SMTP server for email testing",
      "type": "shell",
      "command": "./Run-MailHog.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    }
  ]
}
