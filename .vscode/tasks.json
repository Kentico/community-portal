{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Aspire: Run",
      "detail": "Orchestrate the full local dev stack (SQL Server, Azurite, client dev servers, web app) with the Aspire dashboard",
      "type": "shell",
      "command": "aspire run",
      "isBackground": true,
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": ".NET: build (Solution)",
      "type": "shell",
      "command": "./Build-Solution.ps1",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": ".NET: rebuild (Solution)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "--no-incremental",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": ".NET: deep clean (Solution)",
      "type": "shell",
      "command": "./DeepClean-BuildArtifacts.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": ".NET: publish (Web)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/src/Kentico.Community.Portal.Web/Kentico.Community.Portal.Web.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": ".NET: watch (Web)",
      "command": "dotnet",
      "type": "process",
      "args": ["watch"],
      "options": {
        "cwd": "${workspaceFolder}/src/Kentico.Community.Portal.Web",
        "env": {
          "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true"
        }
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": ".NET: run (Web)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/Kentico.Community.Portal.Web/Kentico.Community.Portal.Web.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": ".NET: test (Solution)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        // https://learn.microsoft.com/en-us/dotnet/core/testing/unit-testing-nunit-runner-intro
        "--settings",
        "./test/basic.runsettings",
        "--no-build"
      ],
      "problemMatcher": "$msCompile",
      "isTestCommand": true
    },
    {
      "label": ".NET: format (Solution)",
      "command": "dotnet",
      "type": "process",
      "args": ["format"],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "pnpm: install (workspace)",
      "type": "shell",
      "group": "none",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "pnpm install",
      "problemMatcher": [],
      "detail": "Install all pnpm workspace dependencies (Web + Admin clients) from the repo root"
    },
    {
      "label": "pnpm: audit fix (Web)",
      "type": "shell",
      "options": {
        "cwd": "src/Kentico.Community.Portal.Web"
      },
      "command": "pnpm audit --fix=update",
      "problemMatcher": []
    },
    {
      "label": "pnpm: audit fix (Admin)",
      "type": "shell",
      "options": {
        "cwd": "src/Kentico.Community.Portal.Admin/Client"
      },
      "command": "pnpm audit --fix=update",
      "problemMatcher": []
    },
    {
      "label": "pnpm: watch (Web)",
      "type": "shell",
      "command": "pnpm start",
      "problemMatcher": [],
      "options": {
        "cwd": "src/Kentico.Community.Portal.Web"
      },
      "dependsOn": ["pnpm: install (workspace)"],
      "detail": "Vite development server"
    },
    {
      "label": "pnpm: watch (Admin)",
      "type": "shell",
      "command": "pnpm start",
      "group": "build",
      "problemMatcher": [],
      "options": {
        "cwd": "src/Kentico.Community.Portal.Admin/Client"
      },
      "dependsOn": ["pnpm: install (workspace)"],
      "detail": "Webpack development server"
    },
    {
      "label": "pnpm: build (Web)",
      "type": "shell",
      "command": "pnpm build",
      "group": "build",
      "problemMatcher": [],
      "options": {
        "cwd": "src/Kentico.Community.Portal.Web"
      },
      "dependsOn": ["pnpm: install (workspace)"],
      "detail": "Build Web client assets (CSS, JS) with Vite"
    },
    {
      "label": "pnpm: build (Admin)",
      "type": "shell",
      "command": "pnpm build",
      "group": "build",
      "problemMatcher": [],
      "options": {
        "cwd": "src/Kentico.Community.Portal.Admin/Client"
      },
      "dependsOn": ["pnpm: install (workspace)"],
      "detail": "Build Admin client assets (CSS, JS) with Webpack"
    },
    {
      "label": "pnpm: install (Playwright E2E)",
      "type": "shell",
      "group": "none",
      "options": {
        "cwd": "test/kentico-community-portal-web-e2e-tests"
      },
      "command": "pnpm install",
      "problemMatcher": [],
      "detail": "Install Playwright E2E pnpm dependencies"
    },
    {
      "label": "pnpm: install browsers (Playwright E2E)",
      "type": "shell",
      "command": "pnpm install:browsers",
      "group": "none",
      "problemMatcher": [],
      "options": {
        "cwd": "test/kentico-community-portal-web-e2e-tests"
      },
      "dependsOn": ["pnpm: install (Playwright E2E)"],
      "detail": "Install Chromium for Playwright E2E"
    },
    {
      "label": "pnpm: audit fix (Playwright E2E)",
      "type": "shell",
      "options": {
        "cwd": "test/kentico-community-portal-web-e2e-tests"
      },
      "command": "pnpm audit --fix=update",
      "problemMatcher": []
    },
    {
      "label": "pnpm: test (Playwright E2E)",
      "type": "shell",
      "command": "pnpm test",
      "problemMatcher": [],
      "options": {
        "cwd": "test/kentico-community-portal-web-e2e-tests",
        "env": {
          "NODE_OPTIONS": "--no-warnings"
        }
      },
      "dependsOn": ["pnpm: install browsers (Playwright E2E)"],
      "detail": "Run Playwright E2E tests"
    },
    {
      "label": "pnpm: test headed (Playwright E2E)",
      "type": "shell",
      "command": "pnpm test:headed",
      "problemMatcher": [],
      "options": {
        "cwd": "test/kentico-community-portal-web-e2e-tests",
        "env": {
          "NODE_OPTIONS": "--no-warnings"
        }
      },
      "dependsOn": ["pnpm: install browsers (Playwright E2E)"],
      "detail": "Run Playwright E2E tests in headed mode"
    },
    {
      "label": "pnpm: test UI (Playwright E2E)",
      "type": "shell",
      "command": "pnpm test:ui",
      "problemMatcher": [],
      "options": {
        "cwd": "test/kentico-community-portal-web-e2e-tests",
        "env": {
          "NODE_OPTIONS": "--no-warnings"
        }
      },
      "dependsOn": ["pnpm: install browsers (Playwright E2E)"],
      "detail": "Run Playwright E2E tests in UI mode"
    },
    {
      "label": "pnpm: test smoke (Playwright E2E)",
      "type": "shell",
      "command": "pnpm test:smoke",
      "problemMatcher": [],
      "options": {
        "cwd": "test/kentico-community-portal-web-e2e-tests",
        "env": {
          "NODE_OPTIONS": "--no-warnings"
        }
      },
      "dependsOn": ["pnpm: install browsers (Playwright E2E)"],
      "detail": "Run Playwright E2E smoke tests"
    },
    {
      "label": "pnpm: report (Playwright E2E)",
      "type": "shell",
      "command": "pnpm report",
      "problemMatcher": [],
      "options": {
        "cwd": "test/kentico-community-portal-web-e2e-tests"
      },
      "detail": "Open Playwright HTML report"
    },
    {
      "label": "Xperience: CI Store",
      "detail": "Updates the CI repository with all valid objects from the local database",
      "type": "shell",
      "command": "./Store-CI.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: CI Restore",
      "detail": "Updates the local database with all the objects in the CI repository",
      "type": "shell",
      "command": "./Restore-CI.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: CI Enable",
      "detail": "Enables Continuous Integration using the Xperience CLI command",
      "type": "shell",
      "command": "./Enable-CI.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: CI Disable",
      "detail": "Disables Continuous Integration using the Xperience CLI command",
      "type": "shell",
      "command": "./Disable-CI.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: CI Status",
      "detail": "Displays Continuous Integration state using the Xperience CLI command",
      "type": "shell",
      "command": "./Get-CI-Status.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: Application Update",
      "detail": "Updates local database data and schema to the version of the project's referenced Xperience NuGet package",
      "type": "shell",
      "command": "./Update-Xperience.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: Database Backup",
      "detail": "Creates a .bak of the Kentico Community database",
      "type": "shell",
      "command": "./Backup-Database.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: Update Generated Code Files",
      "detail": "Updates generated code files in the repository (uses script settings)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/Refresh-GeneratedCode.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Xperience: Generate Deployment Package",
      "detail": "Generates a deployment package of the project for the Xperience SaaS environment",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/Export-DeploymentPackage.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "MailHog: Start Server",
      "detail": "Starts MailHog SMTP server for email testing",
      "type": "shell",
      "command": "./Run-MailHog.ps1",
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    }
  ]
}
